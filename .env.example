# PostgreSQL (Railway)
DATABASE_URL=postgresql://user:password@host:5432/railway

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:4200

# Game defaults
INITIAL_BALANCE=5000

# --- Resend (correos transaccionales) ---
# 1. Crear cuenta en https://resend.com
# 2. API key: https://resend.com/api-keys
# 3. Dev: usar onboarding@resend.dev (solo envía al correo dueño de la cuenta)
# 4. Prod: verificar dominio en https://resend.com/domains y usar noreply@tudominio.com
RESEND_API_KEY=re_your_api_key_here

# Remitente visible en los correos
# Dev:
EMAIL_FROM=Guayabita <onboarding@resend.dev>
# Prod (descomentar cuando el dominio esté verificado):
# EMAIL_FROM=Guayabita <noreply@tudominio.com>

# URL pública del frontend Angular (Vercel en prod). Los links de correo apuntan aquí.
FRONTEND_URL=http://localhost:4200
# Prod:
# FRONTEND_URL=https://tu-app.vercel.app

# TTL de tokens en Redis
EMAIL_VERIFY_TOKEN_TTL_HOURS=48
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# --- Cloudflare R2 (fotos de perfil) ---
R2_ACCESS_KEY_ID=406bc93c70d377455d7d582d55b69c0d
R2_SECRET_ACCESS_KEY=1936151565ead5a5fa567c9b7ba0d321e8ce57c0659c6b9865ce62790333db6d
R2_BUCKET=guayabita
R2_ENDPOINT=https://d5c7492ed55635480d914128a034830b.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-e757249f81024d12a9d126d3f191c104.r2.dev

# Avatar por defecto (ruta local del frontend Angular)
DEFAULT_AVATAR_URL=/images/avatar-default.png

# Usuario que será promovido a administrador al iniciar el backend (opcional)
INITIAL_ADMIN_USERNAME=lordComando
